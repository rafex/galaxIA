#!/usr/bin/env bash
# pre-commit — ejecuta lint, typecheck y regenera version.json
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"

echo "→ ESLint..."
npm run lint --workspaces --if-present --prefix "$ROOT" 2>&1 | tail -5

echo "→ Typecheck..."
npm run typecheck --workspaces --prefix "$ROOT"

echo "→ Regenerando version.json..."
"$ROOT/helpers/scripts/shell/gen-version.sh"

echo "✓ pre-commit OK"
