# Contenedor del proveedor MCP OCR
# Expone un servidor MCP HTTP con una tool de OCR basada en Tesseract.

FROM python:3.11-slim

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        tesseract-ocr \
        tesseract-ocr-spa \
        libtesseract-dev \
        && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY containers/ocr-mcp/requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

COPY containers/ocr-mcp/*.py ./

EXPOSE 8082

ENV PORT=8082
ENV REGISTRY_URL=ws://agent-server:8081/fhs/v1/ws
ENV PROVIDER_ID=did:key:ocr-container-01
ENV PROVIDER_NAME="OCR Container"

CMD ["python", "ocr_server.py"]
