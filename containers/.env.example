# Variables para containers/compose.release.yaml — copiar a .env en el
# mismo directorio y editar según tu despliegue. Ver docs/instalacion.md.

# Versión a desplegar (tag de imagen en ghcr.io/rafex/galaxia-*).
# "latest" apunta siempre a la última publicada; fijar una versión exacta
# (ej. v0.1.0-beta.1) es más reproducible para un despliegue real.
GALAXIA_VERSION=latest

# Puertos publicados en el host. Cambiar solo si ya usas esos puertos para
# otra cosa.
ATLAS_PORT=30083
PORTAL_PORT=3000

# Solo necesario si Atlas/Navigator viven en OTRA máquina que el Portal
# (topología multi-host, ver docs/instalacion.md) — en un solo host con
# este mismo compose.release.yaml, los defaults (Docker DNS: atlas/
# navigator) ya funcionan sin tocar esto.
# ATLAS_URL=http://192.168.1.50:8081
# NAVIGATOR_URL=http://192.168.1.51:8090
