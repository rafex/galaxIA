# Contenedor del Agent Backend FHS v0.1
# Expone API REST, SSE y WebSocket de registro en el puerto 8081.

FROM docker.io/library/node:20-alpine AS builder
WORKDIR /app

# Copiar metadatos del workspace
COPY package*.json ./
COPY packages/fhs-protocol/package.json ./packages/fhs-protocol/
COPY apps/agent-server/package.json ./apps/agent-server/
COPY apps/web/package.json ./apps/web/

# Instalar dependencias de producción/desarrollo
RUN npm ci

# Copiar código fuente y construir
COPY packages/fhs-protocol ./packages/fhs-protocol
COPY apps/agent-server ./apps/agent-server

RUN npm run build -w packages/fhs-protocol && \
    npm run build -w apps/agent-server

# Imagen final mínima
FROM docker.io/library/node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=8081
ENV HOST=0.0.0.0

COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/fhs-protocol/package.json ./packages/fhs-protocol/
COPY --from=builder /app/packages/fhs-protocol/dist ./packages/fhs-protocol/dist
COPY --from=builder /app/apps/agent-server/package.json ./apps/agent-server/
COPY --from=builder /app/apps/agent-server/dist ./apps/agent-server/dist

WORKDIR /app/apps/agent-server
EXPOSE 8081

CMD ["node", "dist/index.js"]
