# Contenedor del frontend FHS Chat Web
# Sirve la aplicación compilada con Nginx y proxya /api al agent-server.

FROM node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
COPY packages/fhs-protocol/package.json ./packages/fhs-protocol/
COPY apps/agent-server/package.json ./apps/agent-server/
COPY apps/web/package.json ./apps/web/

RUN npm ci

COPY packages/fhs-protocol ./packages/fhs-protocol
COPY apps/web ./apps/web

RUN npm run build -w packages/fhs-protocol && \
    npm run build -w apps/web

FROM docker.io/library/nginx:alpine
COPY --from=builder /app/apps/web/dist /usr/share/nginx/html
COPY containers/web/nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
