# Contenedor del LLM Provider FHS
# Recubre llama.cpp con el protocolo FHS WebSocket.
# Expone chat FHS en puerto 43111.

FROM docker.io/library/node:20-alpine AS builder
WORKDIR /app

COPY package*.json ./
COPY packages/fhs-protocol/package.json ./packages/fhs-protocol/
COPY examples/llm-provider/package.json ./examples/llm-provider/

RUN npm ci

COPY packages/fhs-protocol ./packages/fhs-protocol
COPY examples/llm-provider ./examples/llm-provider

RUN npm run build -w packages/fhs-protocol && \
    npm run build -w examples/llm-provider

FROM docker.io/library/node:20-alpine
WORKDIR /app
ENV NODE_ENV=production

COPY --from=builder /app/package*.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/fhs-protocol/package.json ./packages/fhs-protocol/
COPY --from=builder /app/packages/fhs-protocol/dist ./packages/fhs-protocol/dist
COPY --from=builder /app/examples/llm-provider/package.json ./examples/llm-provider/
COPY --from=builder /app/examples/llm-provider/dist ./examples/llm-provider/dist

WORKDIR /app/examples/llm-provider
EXPOSE 43111

ENV LLM_PROVIDER_PORT=43111
ENV REGISTRY_URL=ws://agent-server:8081/fhs/v1/ws
ENV LLAMA_CPP_URL=http://host.containers.internal:43110/v1
ENV PROVIDER_ID=did:key:macmini-raul
ENV PROVIDER_NAME="Mac mini de Raul"

CMD ["node", "dist/index.js"]
