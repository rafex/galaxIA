{
  "name": "@galaxia/navigator",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Navigator (Agent Runtime) de FHS v0.1: orquesta LLM/tools vía Atlas + API REST/WS de chat.",
  "bin": {
    "galaxia-navigator": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "sh ../../helpers/scripts/shell/gen-version.sh 2>/dev/null || true; tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/websocket": "11.3.0",
    "@rafex/galaxia-fhs-protocol": "^0.1.0",
    "fastify": "5.10.0",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@types/node": "20.19.43",
    "@types/ws": "8.18.1",
    "tsx": "4.22.4",
    "typescript": "5.9.3"
  }
}
